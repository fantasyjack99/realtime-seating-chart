{
  "entities": {
    "Seat": {
      "title": "Seat",
      "description": "Represents a physical seat or location in the office.",
      "type": "object",
      "properties": {
        "Seat_ID": { "type": "string", "description": "Unique identifier for the seat." },
        "Staff_Name": { "type": "string", "description": "Name of the staff member occupying the seat." },
        "Title": { "type": "string", "description": "Job title of the staff member." },
        "Extension": { "type": "string", "description": "Phone extension number." },
        "Port_ID": { "type": "string", "description": "Network port identifier." },
        "Network_Jack": { "type": "string", "description": "Network jack identifier." },
        "Department": { "type": "string", "description": "Department the seat belongs to." },
        "Section": { "type": "string", "description": "Section within the department." },
        "Is_Static": { "type": "number", "description": "Indicates if the seat is a static location (e.g., printer, server room). 1 for static, 0 for regular." }
      },
      "required": ["Seat_ID", "Staff_Name", "Is_Static"]
    },
    "Department": {
      "title": "Department",
      "description": "Configuration for a department and its sections.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the department configuration." },
        "department": { "type": "string", "description": "Name of the department." },
        "section": { "type": "string", "description": "Name of the section." },
        "color": { "type": "string", "description": "Hex color code for the department." }
      },
      "required": ["id", "department", "section", "color"]
    },
    "PhoneDirectoryLayout": {
      "title": "Phone Directory Layout",
      "description": "Configuration for the layout of the phone directory.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the layout configuration." },
        "column_index": { "type": "number", "description": "Column index in the layout." },
        "department": { "type": "string", "description": "Name of the department." },
        "sort_order": { "type": "number", "description": "Sort order within the column." }
      },
      "required": ["id", "column_index", "department", "sort_order"]
    }
  },
  "firestore": {
    "seats": {
      "schema": { "$ref": "#/entities/Seat" },
      "description": "Collection of all seats."
    },
    "departments": {
      "schema": { "$ref": "#/entities/Department" },
      "description": "Collection of department configurations."
    },
    "phone_directory_layout": {
      "schema": { "$ref": "#/entities/PhoneDirectoryLayout" },
      "description": "Collection of phone directory layout configurations."
    }
  }
}
